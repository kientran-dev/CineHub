              "raw": "{\n    \"movieId\": 1,\n    \"title\": \"Tập 1 (HD)\",\n    \"episodeNumber\": 1,\n    \"videoUrl\": \"https://example.com/video1-hd.mp4\",\n    \"duration\": 2750\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/episodes/1",

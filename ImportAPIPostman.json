{
  "info": {
    "name": "CineHub Full API",
    "description": "Bộ API đầy đủ cho các module: Movie, Genre, Episode, WatchHistory, User",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Movies",
      "item": [
        {
          "name": "Get All Movies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/movies",
              "host": ["{{baseUrl}}"],
              "path": ["movies"]
            }
          }
        },
        {
          "name": "Get Movie by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/movies/1",
              "host": ["{{baseUrl}}"],
              "path": ["movies", "1"]
            }
          }
        },
        {
          "name": "Create Movie",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Inception\",\n    \"englishTitle\": \"Inception\",\n    \"thumbnail\": \"https://example.com/thumb.jpg\",\n    \"poster\": \"https://example.com/poster.jpg\",\n    \"director\": \"Christopher Nolan\",\n    \"releaseYear\": 2010,\n    \"country\": \"USA\",\n    \"status\": \"RELEASED\",\n    \"type\": \"MOVIE\",\n    \"imdbScore\": 8.8\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/movies",
              "host": ["{{baseUrl}}"],
              "path": ["movies"]
            }
          }
        },
        {
          "name": "Update Movie",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Inception (Remastered)\",\n    \"englishTitle\": \"Inception\",\n    \"thumbnail\": \"https://example.com/thumb-updated.jpg\",\n    \"poster\": \"https://example.com/poster.jpg\",\n    \"director\": \"Christopher Nolan\",\n    \"releaseYear\": 2010,\n    \"country\": \"USA\",\n    \"status\": \"RELEASED\",\n    \"type\": \"MOVIE\",\n    \"imdbScore\": 9.0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/movies/1",
              "host": ["{{baseUrl}}"],
              "path": ["movies", "1"]
            }
          }
        },
        {
          "name": "Delete Movie",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/movies/1",
              "host": ["{{baseUrl}}"],
              "path": ["movies", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Genres",
      "item": [

            }
          }
        }
      ]
    },
    {
      "name": "5. Watch History",
      "item": [
        {
          "name": "Get Watch History by User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/watch-history/user/1",
              "host": ["{{baseUrl}}"],
              "path": ["watch-history", "user", "1"]
            }
          }
        },
        {
          "name": "Save Watch History",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userId\": 1,\n    \"episodeId\": 1,\n    \"progressTime\": 1250,\n    \"isCompleted\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/watch-history",
              "host": ["{{baseUrl}}"],
              "path": ["watch-history"]
            }
          }
        },
        {
          "name": "Clear Watch History",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/watch-history/1",
              "host": ["{{baseUrl}}"],
              "path": ["watch-history", "1"]
            }
          }
        }
      ]
    }
  ]
}
          }
        },
        {
          "name": "Delete Genre",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/genres/1",
              "host": ["{{baseUrl}}"],
              "path": ["genres", "1"]
            }
          }
        }
      ]
    },
